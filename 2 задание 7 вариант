#include <iostream>
#include <string>

using namespace std;

int main() {
    string d;
    cout << "Введите день недели: ";
    cin >> d;

    for (char &c : d) {
        c = tolower(c);
    }

    if (d == "Понедельник" || d == "Вторник" || d == "Среда" ||
        d == "Четверг" || d == "Пятница") {
        cout << "Прием с 8:00 до 12:00" << endl;
    }
    else if (d == "Суббота" || d == "Воскресенье") {
        cout << "В этот день приема нет." << endl;
    }
    else {
        cout << " только полное название дня недели с заглавной буквы" << endl;
    }

    return 0;
}